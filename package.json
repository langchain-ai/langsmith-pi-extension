{
  "name": "@langchain/langsmith-pi-extension",
  "version": "0.1.0",
  "description": "LangSmith extension for Pi Coding Agent",
  "keywords": [
    "coding-agent",
    "langsmith",
    "pi",
    "pi-package"
  ],
  "license": "MIT",
  "author": "LangChain",
  "repository": {
    "type": "git",
    "url": "https://github.com/langchain-ai/langsmith-pi-extension.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/inject-version.mjs && tsc",
    "test": "vitest",
    "pretest": "node scripts/inject-version.mjs",
    "format": "oxfmt",
    "lint": "oxfmt --check && tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepublish": "pnpm run build"
  },
  "dependencies": {
    "langsmith": "^0.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "js-yaml@3": "3.15.0",
      "js-yaml@4": "4.3.0",
      "protobufjs": "7.6.5",
      "undici": "8.5.0",
      "ws": "8.21.0"
    }
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
